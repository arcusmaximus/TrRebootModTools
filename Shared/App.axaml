<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="TrRebootTools.Shared.App"
             xmlns:controls="using:TrRebootTools.Shared.Controls"
             RequestedThemeVariant="Default">
    <Application.Resources>
		<ResourceDictionary>
			<ResourceDictionary.ThemeDictionaries>
				<ResourceDictionary x:Key="Default">
					<Color x:Key="TextHighlight">#E6E6FA</Color>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
					<Color x:Key="TextHighlight">#7474D3</Color>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
    <Application.Styles>
        <SimpleTheme />

        <Style Selector="TabControl[TabStripPlacement=Top]">
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="TabControl > Border > DockPanel > ItemsPresenter > WrapPanel">
            <Setter Property="ItemSpacing" Value="2"/>
        </Style>
        <Style Selector="TabControl > Border > DockPanel > ContentPresenter">
			<Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderLowBrush}"/>
            <Setter Property="BorderThickness" Value="0 1 0 0"/>
            <Setter Property="Padding" Value="0 4 0 0"/>
        </Style>
        <Style Selector="TabItem">
			<Setter Property="FontSize" Value="{DynamicResource FontSizeNormal}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderLowBrush}"/>
            <Setter Property="BorderThickness" Value="1 1 1 0"/>
            <Setter Property="CornerRadius" Value="5 5 0 0" />
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style Selector="ListBox > Border > DockPanel > controls|ListViewRow">
			<Setter Property="Background" Value="{DynamicResource ThemeControlMidBrush}"/>
        </Style>

        <Style Selector="Run.highlight">
			<Setter Property="Background" Value="{DynamicResource TextHighlight}" />
        </Style>
    </Application.Styles>
</Application>