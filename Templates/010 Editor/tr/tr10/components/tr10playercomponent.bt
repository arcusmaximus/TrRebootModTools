typedef struct
{
    byte enableHealthPrim;
    FSkip(3);
    HealthComponent_ApplyArmorType applyType;
    local int applyEndPos = FTell() + 0x10;
    switch (applyType)
    {
        case HealthComponent_ApplyArmorType_OnPrim:
            HealthComponent__OnPrimList onPrim;
            break;
        case HealthComponent_ApplyArmorType_OnHPrimNumber:
            int onHPrimNumber;
            break;
        case HealthComponent_ApplyArmorType_OnAll:
            break;
    }
    FSeek(applyEndPos);
    unsigned int armorListCount;
    FSkip(4);
    Ref armorListRef;
    if (CanSeekTo(armorListRef))
    {
        SeekToRef(armorListRef);
