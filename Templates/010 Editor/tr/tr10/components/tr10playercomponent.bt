typedef struct
{
    byte startActive;
    byte ignorePlayerOverrides;
    byte delayCreateTilActivated;
    FSkip(1);
    float dilationPercent;
    int screenID;
    int inputControllerID;
    int inputControllerSource;
    byte inputStartsEnabled;
    FSkip(3);
    CameraType cameraType;
    unsigned int categoryHash;
    local int controllerEndPos = FTell() + 0x3F0;
    switch (cameraType)
    {
        case CameraType_FreeCamController:
            FreeCamController freeCamController;
            break;
        case CameraType_SimpleCamController:
            SimpleCamController simpleCamController;
            break;
        case CameraType_IsoCamController:
            IsoCamController isoCamController;
            break;
        case CameraType_MapViewCamController:
            MapViewCamController mapViewCamController;
            break;
        case CameraType_ModelviewCamController:
            ModelviewCamController modelviewCamController;
            break;
        case CameraType_AnchoredCamController:
            AnchoredCamController anchoredCamController;
            break;
        case CameraType_SplineCamController:
            SplineCamController splineCamController;
            break;
        case CameraType_DummyCamController:
        case CameraType_ForceCamController:
            ForceCamController forceCamController;
            break;
        case CameraType_CameraBoneCamController:
            CameraBoneCamController cameraBoneCamController;
            break;
        case CameraType_ExplorationCamController:
            ExplorationCamController explorationCamController;
            break;
        case CameraType_AimCamController:
            AimCamController aimCamController;
            break;
        case CameraType_StealthCamController:
            StealthCamController stealthCamController;
            break;
        case CameraType_HmdCamController:
            HmdCamController hmdCamController;
            break;
    }
    FSeek(controllerEndPos);
} CameraComponent <optimize=false>;

