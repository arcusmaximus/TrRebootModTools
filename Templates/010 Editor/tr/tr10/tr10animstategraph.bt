void ReadNodeProperties(string type)
{
    switch (type)
    {        
        case "AimJoint":
            ReadAimJointNode();
            break;
        case "AnimDrivenRagdoll":
            ReadAnimDrivenRagdollNode();
            break;
        case "AnimTarget":
            ReadAnimTargetNode();
            break;
        case "AnimTargetOneAxis":
            ReadAnimTargetOneAxisNode();
            break;
        case "ApplyRotation":
            ReadApplyRotationNode();
            break;
        case "ApplyTranslation":
            ReadApplyTranslationNode();
            break;
        case "AutoHosted":
            ReadAutoHostedNode();
            break;
        case "Blend":
            ReadBlendNode();
            break;
        case "BoneSet":
            ReadBoneSetNode();
            break;
        case "BoneSpring":
            ReadBoneSpringNode();
            break;
        case "bonetransform":
            ReadBoneTransformNode();
            break;
        case "FaceFxNode":
            ReadFaceFxNode();
            break;
        case "FlagLogic":
            ReadFlagLogicNode();
            break;
        case "Fragment":
            ReadFragmentNode();
            break;
        case "HeadTracking":
            ReadHeadTrackingNode();
            break;
        case "Hosted":
            ReadHostedNode();
            break;
        case "HostedOverlay":
            ReadHostedOverlayNode();
            break;
        case "Mirror":
            ReadMirrorNode();
            break;
        case "Modifier":
            ReadModifierNode();
            break;
        case "OverlayPose":
            ReadOverlayPoseNode();
            break;
        case "PreviousPose":
            ReadPreviousPoseNode();
            break;
        case "RagdollData":
            ReadRagdollDataNode();
            break;
        case "Ragdoll":
            ReadRagdollNode();
            break;
        case "ScalarCombine":
            ReadScalarCombineNode();
            break;
        case "ScalarCurve":
            ScalarCurveNode();
            break;
        case "ScalarGenerator":
            ReadScalarGeneratorNode();
            break;
        case "ScalarToVector":
            ReadScalarToVectorNode();
            break;
        case "SimpleIK":
            ReadSimpleIKNode();
            break;
        case "Sync":
            ReadSyncNode();
            break;
        case "SyncToCine":
            ReadSyncToCineNode();
            break;
        case "VectorHeading":
            ReadVectorHeadingNode();
            break;
        case "VectorSubtract":
            ReadVectorSubtractNode();
            break;
        case "Wind":
            ReadWindNode();
            break;
    }
}

enum <byte> AnimGraphNodeType
{
    AnimGraphNodeType_AnimNode,
    AnimGraphNodeType_EmbeddedNodeGraph,
    AnimGraphNodeType_EmbeddedStateGraph,
    AnimGraphNodeType_CustomNode
};

typedef struct
{
    StringRef name;
    AnimGraphNodeType type;
    FSkip(7);
    local int endPos = FTell() + 0x18;
    switch (type)
    {
        case AnimGraphNodeType_AnimNode:
            uint nodeTypeHash <format=hex>;
            FSkip(4);
            StringRef nodeTypeName;
            Ref propertiesRef;
            if (CanSeekTo(propertiesRef))
            {
                SeekToRef(propertiesRef);
                ReadNodeProperties(nodeTypeName.value);
                ReturnFromRef();
            }
            break;
        
        case AnimGraphNodeType_EmbeddedNodeGraph:
            Ref nodeGraphRef;
            if (CanSeekTo(nodeGraphRef))
            {
                SeekToRef(nodeGraphRef);
                AnimNodeGraph graph;
                ReturnFromRef();
            }
            break;
        
        case AnimGraphNodeType_EmbeddedStateGraph:
            Ref stateGraphRef;
            if (CanSeekTo(stateGraphRef))
            {
                SeekToRef(stateGraphRef);
                AnimStateGraph stateGraph;
                ReturnFromRef();
            }
            break;
        
        case AnimGraphNodeType_CustomNode:
            int callback;
            FSkip(4);
            Ref inputSocketTypesRef;      // char*
            Ref outputSocketTypesRef;
            break;
    }
    FSeek(endPos);
    StringRef dtpArrayIndex;
} AnimGraphNode <optimize=false, read=name.value>;

typedef struct
{
    ushort id;
} Symbol <read=GetSymbolName(id)>;

typedef struct
{
    Symbol srcSocketId;
    Symbol dstSocketId;
    short dstSocketIndex;
    short srcSocketIndex;
    ubyte srcNode;
    ubyte dstNode;
} AnimGraphEdge <read=Str(
    "%s.%s -> %s.%s",
    srcNode == 0xFF ? "[Inputs]"  : parentof(this).nodes[srcNode].name.value,
    GetSymbolName(srcSocketId.id),
    dstNode == 0xFF ? "[Outputs]" : parentof(this).nodes[dstNode].name.value,
    GetSymbolName(dstSocketId.id)
)>;

enum <byte> AnimGraphDataType
{
    AnimGraphDataType_Pose,
    AnimGraphDataType_Scalar,
    AnimGraphDataType_Vector3,
    AnimGraphDataType_Matrix,
    AnimGraphDataType_BoneSet,
    AnimGraphDataType_RagdollData,
    AnimGraphDataType_IKData,
    AnimGraphDataType_Flag,
    AnimGraphDataType_Quat,
    AnimGraphDataType_IKTarget
};

typedef struct
{
    StringRef name;
    Symbol socketId;
    Symbol rtValue;
    FSkip(4);
    local int typePos = FTell() + 0x10;
    local AnimGraphDataType _type = ReadByte(typePos);
    switch (_type)
    {
        case AnimGraphDataType_Pose:
            Ref defaultValueRef;
            break;
        case AnimGraphDataType_Scalar:
            float defaultValue;
            break;
        case AnimGraphDataType_Vector3:
            Vector3 defaultValue;
            break;
        case AnimGraphDataType_Matrix:
            Ref defaultValueRef;
            if (CanSeekTo(matrixRef))
            {
                SeekToRef(defaultValueRef);
                Matrix matrix;
                ReturnFromRef();
            }
            break;
        case AnimGraphDataType_BoneSet:
            ubyte defaultValue;
            break;
        case AnimGraphDataType_RagdollData:
            Ref defaultValueRef;
            break;
        case AnimGraphDataType_IKData:
            Ref defaultValueRef;
            break;
        case AnimGraphDataType_Flag:
            byte defaultValue;
            break;
        case AnimGraphDataType_Quat:
            Quaternion defaultValue;
            break;
        case AnimGraphDataType_IKTarget:
            Ref defaultValueRef;
            break;
    }
    FSeek(typePos);
    AnimGraphDataType type;
    byte source;
    FSkip(6);
} GraphIOSocket <optimize=false, read=name.value>;

typedef struct
{
    ubyte numNodes;
    ubyte numEdges;
    ubyte numInputs;
    ubyte numOutputs;
    FSkip(4);
    Ref nodesRef;
    if (CanSeekTo(nodesRef))
    {
        SeekToRef(nodesRef);
        AnimGraphNode nodes[numNodes];
        ReturnFromRef();
    }
    Ref edgesRef;
    if (CanSeekTo(edgesRef))
    {
        SeekToRef(edgesRef);
        AnimGraphEdge edges[numEdges];
        ReturnFromRef();
    }
    Ref inputsRef;
    if (CanSeekTo(inputsRef))
    {
        SeekToRef(inputsRef);
        GraphIOSocket inputs[numInputs];
        ReturnFromRef();
    }
    Ref outputsRef;
    if (CanSeekTo(outputsRef))
    {
        SeekToRef(outputsRef);
        GraphIOSocket outputs[numOutputs];
        ReturnFromRef();
    }
} AnimNodeGraph <optimize=false>;

