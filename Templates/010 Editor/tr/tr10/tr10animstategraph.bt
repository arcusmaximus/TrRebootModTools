enum <int> ModifierNodeType
{
    ModifierNodeType_Timing,
    ModifierNodeType_TimingFrames,
    ModifierNodeType_RootTranslation
};

enum <int> ModifierNodeRootTranslationSubType
{
    ModifierNodeRootTranslationSubType_Absolute
};

void ReadModifierNode()
{
    ModifierNodeType modifierNodeType;
    switch (modifierNodeType)
    {
        case ModifierNodeType_Timing:
        case ModifierNodeType_TimingFrames:
            int subType;
            byte overwriteSyncParams;
            byte dontModifyDuration;
            byte loopMode;
            FSkip(1);
            float playspeed;
            break;
        
        case ModifierNodeType_RootTranslation:
            ModifierNodeRootTranslationSubType subType;
            break;
    }
}

