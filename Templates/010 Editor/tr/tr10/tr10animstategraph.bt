typedef struct
{
    Symbol rTFlag;
    char operation;
} RTFlagOperation <optimize=false>;

enum <byte> AnimGraphType
{
    AnimGraphType_Nodes,
    AnimGraphType_States,
    AnimGraphType_TransientState
};

typedef struct
{
    StringRef name;
    StringRef dtpArrayIndex;
    Ref graphRef;
    Ref doneEventsListRef;
    StateUserData userData;
    AnimGraphType graphType;
    FSkip(7);
    if (CanSeekTo(graphRef))
    {
        SeekToRef(graphRef);
        switch (graphType)
        {
            case AnimGraphType_Nodes:
                AnimNodeGraph nodeGraph;
                break;
            case AnimGraphType_States:
                AnimStateGraph stateGraph;
                break;
            case AnimGraphType_TransientState:
                TransientStateType transientState;
                break;
        }
        ReturnFromRef();
    }
    Ref rtFlagOperationsEnterRef;
    Ref rtFlagOperationsExitRef;
    byte bSendStateDoneMessage;
    byte bSendStateDoneMessageOnExit;
    ubyte doneEventsCount;
    if (CanSeekTo(doneEventsListRef))
    {
        SeekToRef(doneEventsListRef);
        StateDoneEvent doneEventsList[doneEventsCount];
        ReturnFromRef();
    }
    byte bUsePrevStateSnapshot;
    byte assertOnEarlyExitAndNotDone;
    FSkip(3);
    unsigned int animCompleteID <format=hex>;
    ubyte numRTFlagOperationsEnter;
    if (CanSeekTo(rtFlagOperationsEnterRef))
    {
        SeekToRef(rtFlagOperationsEnterRef);
        RTFlagOperation rtFlagOperationsEnter[numRTFlagOperationsEnter];
        ReturnFromRef();
    }
    ubyte numRTFlagOperationsExit;
    if (CanSeekTo(rtFlagOperationsExitRef))
    {
        SeekToRef(rtFlagOperationsExitRef);
        RTFlagOperation rtFlagOperationsExit[numRTFlagOperationsExit];
        ReturnFromRef();
    }
    FSkip(2);
} State <optimize=false, read=name.value>;

typedef struct
{
    ubyte values[20];
} InterpCurve;

enum <byte> TransitionConditionType
{
    TransitionConditionType_time,
    TransitionConditionType_frame,
    TransitionConditionType_percent,
    TransitionConditionType_rtvalScalar,
    TransitionConditionType_rtvalFlag,
    TransitionConditionType_rtvalSymbol,
    TransitionConditionType_PlayerTraitListIndex,
    TransitionConditionType_AmmoType,
    TransitionConditionType_DamageType,
    TransitionConditionType_HitReactType,
    TransitionConditionType_syncFrame,
    TransitionConditionType_syncPercent,
    TransitionConditionType_randTime,
    TransitionConditionType_randFrame,
    TransitionConditionType_randPercent,
    TransitionConditionType_syncRandFrame,
    TransitionConditionType_syncRandPercent,
    TransitionConditionType_Network,
    TransitionConditionType_IKChainStatus,
    TransitionConditionType_NetData,
    TransitionConditionType_MeleeMoveActiveID,
    TransitionConditionType_HasCustomMovesetHost,
    TransitionConditionType_AnimGraphGoal,
    TransitionConditionType_TimeSinceGoalChange,
    TransitionConditionType_StateControlCondition,
    TransitionConditionType_InstancePersistentFlag,
    TransitionConditionType_InstancePersistentScalar,
    TransitionConditionType_GlobalPersistentFlag,
    TransitionConditionType_GlobalPersistentScalar
};

typedef struct
{
    local int typePos = FTell() + 0x38;
    local TransitionConditionType _type = ReadByte(typePos);
    switch (_type)
    {
        case TransitionConditionType_time:
        case TransitionConditionType_frame:
        case TransitionConditionType_percent:
            float rhs;
            ubyte cmp;
            break;
        case TransitionConditionType_rtvalScalar:
            ushort lhs;
            FSkip(2);
            float rhs;
            ubyte cmp;
            char source;
            break;
        case TransitionConditionType_rtvalFlag:
            ushort lhs;
            char source;
            break;
        case TransitionConditionType_rtvalSymbol:
            ushort lhs;
            ushort rhs;
            char source;
            break;
        case TransitionConditionType_PlayerTraitListIndex:
            ushort lhs;
            char source;
            break;
        case TransitionConditionType_AmmoType:
            unsigned int lhs;
            char source;
            break;
        case TransitionConditionType_DamageType:
            int lhs;
            char source;
            break;
        case TransitionConditionType_HitReactType:
            int lhs;
            char source;
            break;
        case TransitionConditionType_syncFrame:
        case TransitionConditionType_syncPercent:
            unsigned int sync;
            float rhs;
            ubyte cmp;
            break;
        case TransitionConditionType_randTime:
        case TransitionConditionType_randFrame:
        case TransitionConditionType_randPercent:
            float lower;
            float upper;
            ubyte cmp;
            break;
        case TransitionConditionType_syncRandFrame:
        case TransitionConditionType_syncRandPercent:
            unsigned int sync;
            float lower;
            float upper;
            ubyte cmp;
            break;
        case TransitionConditionType_Network:
            char lhs;
            char source;
            break;
        case TransitionConditionType_IKChainStatus:
            StringRef name;
            uint hash;
            int rhs;
            break;
        case TransitionConditionType_NetData:
            // dtp::NetDataCondition*
            break;
        case TransitionConditionType_MeleeMoveActiveID:
            StringRef name;
            unsigned int lhs;
            break;
        case TransitionConditionType_HasCustomMovesetHost:
            AnimGraphHostedMovesetType lhs;
            break;
        case TransitionConditionType_AnimGraphGoal:
            // dtp::RTValGoalCondition
            break;
        case TransitionConditionType_TimeSinceGoalChange:
            int lhs;
            ubyte cmp;
            FSkip(3);
            float rhs;
            char source;
            break;
        case TransitionConditionType_StateControlCondition:
            // dtp::SCConditionDataWithAgent
            break;
        case TransitionConditionType_InstancePersistentFlag:
            ushort name;
            FSkip(2);
            int type;
            break;
        case TransitionConditionType_InstancePersistentScalar:
            ushort name;
            FSkip(2);
            int type;
            float rhs;
            ubyte cmp;
            break;
        case TransitionConditionType_GlobalPersistentFlag:
        case TransitionConditionType_GlobalPersistentScalar:
            ushort name;
            FSkip(2);
            int defaultValueType;
            StringRef comment;
            if (defaultValueType == 2)
            {
                float defaultValue;
            }
            else
            {
                int defaultValue;
            }
            
            if (_type == TransitionConditionType_GlobalPersistentScalar)
            {
                float rhs;
                ubyte cmp;
            }
            break;
    }
    FSeek(typePos);
    TransitionConditionType type;
    byte knot;
    FSkip(6);
} TransitionCondition <optimize=false>;

typedef struct
{
    Ref conditionsRef;
    ubyte numConditions;
    if (CanSeekTo(conditionsRef))
    {
        SeekToRef(conditionsRef);
        TransitionCondition conditions[numConditions];
        ReturnFromRef();
    }
    byte enabled;
} TransitionConditionGroup <optimize=false>;

typedef struct
{
    event event_;
    FSkip(4);
    Ref messageRef;
    if (CanSeekTo(messageRef))
    {
        SeekToRef(messageRef);
        string message;
        ReturnFromRef();
    }
    byte sendToHost;
} PostTransitionEvent <optimize=false>;

typedef struct
{
    int id;
    int scAgentID;
    StringRef debugText;
} AnimStateTransitionUserData <optimize=false, read=debugText.value>;

typedef struct
{
    float interp;
    InterpCurve curve;
    float startTime;
    byte snapshotFrom;
    byte snapshotTo;
    char rootMotionMode;
    byte enabled;
    event trigger;
    char triggerSource;
    FSkip(3);
    Ref conditionGroupsRef;
    Ref rtFlagOperationsRef;
    if (CanSeekTo(rtFlagOperationsRef))
    {
        SeekToRef(rtFlagOperationsRef);
        RTFlagOperation rtFlagOperations;
        ReturnFromRef();
    }
    Ref postTransitionEventsRef;
    ubyte numPostTransitionEvents;
    if (CanSeekTo(postTransitionEventsRef))
    {
        SeekToRef(postTransitionEventsRef);
        PostTransitionEvent postTransitionEvents[numPostTransitionEvents];
        ReturnFromRef();
    }
    byte postTransitionEventsEnabled;
    FSkip(6);
    AnimStateTransitionUserData userData;
    ubyte srcNode;
    ubyte destNode;
    ubyte numConditionGroups;
    if (CanSeekTo(conditionGroupsRef))
    {
        SeekToRef(conditionGroupsRef);
        TransitionConditionGroup conditionGroups[numConditionGroups];
        ReturnFromRef();
    }
    ubyte numRTFlagOperations;
    ubyte transitionPriority;
    byte syncStartTime : 1;
    byte syncStartLoop : 1;
    byte defaultTransition : 1;
    byte correctSnapWhileInterpBehavior : 1;
    byte _padding21 : 4;
    byte showPassFailDebug;
    FSkip(1);
} Transition <optimize=false, read=userData.debugText.value>;

typedef struct
{
    Ref statesRef;
    Ref transitionsRef;
    ubyte numStates;
    if (CanSeekTo(statesRef))
    {
        SeekToRef(statesRef);
        State states[numStates];
        ReturnFromRef();
    }
    ubyte numTransitions;
    if (CanSeekTo(transitionsRef))
    {
        SeekToRef(transitionsRef);
        Transition transitions[numTransitions];
        ReturnFromRef();
    }
    ubyte defaultState;
    byte useStale;
} AnimStateGraph <optimize=false>;

RefDefinitions refDefinitions;
int animLibraryId;
FSkip(4);
Ref stateGraphRef;
if (CanSeekTo(stateGraphRef))
{
    SeekToRef(stateGraphRef);
    AnimStateGraph stateGraph <open=true>;
