typedef struct
{
    unsigned int vocals;
    unsigned int bark;
    byte useObj;
    FSkip(3);
    unsigned int datFile;
} StateControlBark <optimize=false>;

typedef struct
{
    short min;
    short max;
} CameraMoveStick;

void ReadSCPropertyValue(SCPropertyType type)
{
    local int endPos = FTell() + 8;
    switch (type)
    {
        case SCPropertyType_Accuracy:
        case SCPropertyType_ActionType:
        case SCPropertyType_Boolean:
        case SCPropertyType_Calculated:
        case SCPropertyType_CameraComponent:
        case SCPropertyType_CameraShake:
        case SCPropertyType_CameraTransitionType:
        case SCPropertyType_ContactDataType:
        case SCPropertyType_DevelopmentProgress:
        case SCPropertyType_EventTarget:
        case SCPropertyType_EventTime:
        case SCPropertyType_GymnasticsMove:
        case SCPropertyType_HitDamageType:
        case SCPropertyType_Integer:
        case SCPropertyType_IntegerDistanceCm:
        case SCPropertyType_InteractAnim:
        case SCPropertyType_InteractMode:
        case SCPropertyType_Inventory:
        case SCPropertyType_InventoryAnim:
        case SCPropertyType_InventoryItemAnim:
        case SCPropertyType_HostedSCTimer:
        case SCPropertyType_JumpDetectionDir:
        case SCPropertyType_JumpDetectionVel:
        case SCPropertyType_JumpMode:
        case SCPropertyType_LimbLock:
        case SCPropertyType_Message:
        case SCPropertyType_MotionSource:
        case SCPropertyType_MovementSafety:
        case SCPropertyType_MoveSet:
        case SCPropertyType_NetworkContinuityBreak:
        case SCPropertyType_NpcMoverMode:
        case SCPropertyType_NpcProcessTime:
        case SCPropertyType_Orientation:
        case SCPropertyType_Object:
        case SCPropertyType_PortableAnim:
        case SCPropertyType_SCComparison:
        case SCPropertyType_SenseType:
        case SCPropertyType_SensoryType:
        case SCPropertyType_SpatialProbe:
        case SCPropertyType_SteeringMode:
        case SCPropertyType_SteeringDirection:
        case SCPropertyType_SteeringCurveGeneric:
        case SCPropertyType_Timer:
        case SCPropertyType_VehicleAnim:
        case SCPropertyType_WetDirtyMode:
        case SCPropertyType_NpcActionStatus:
        case SCPropertyType_WeaponProjectileType:
        case SCPropertyType_TurnType:
            int value;
            break;
        
        case SCPropertyType_AnimGraphDoubleJointProbeData:
        case SCPropertyType_ControlMode:
        case SCPropertyType_FallHeights:
        case SCPropertyType_InventoryResourceSet:
        case SCPropertyType_JumpVelocity:
        case SCPropertyType_JumpAirSteerTuneData:
        case SCPropertyType_LimbLock:
        case SCPropertyType_LimbLockGroups:
        case SCPropertyType_MarkupDetectionParams:
        case SCPropertyType_SeizeAttack:
        case SCPropertyType_MeleeMove:
        case SCPropertyType_NpcProxyParams:
        case SCPropertyType_ProxyParams:
        case SCPropertyType_ReactiveDodgeParam:
        case SCPropertyType_SenseCone:
        case SCPropertyType_SenseConeGroup:
        case SCPropertyType_SenseUnit:
        case SCPropertyType_SteeringCurveCustom:
        case SCPropertyType_TuningData:
            Ref valueRef;
            break;
            
        case SCPropertyType_AnimGraphGoal:
        case SCPropertyType_AnimGraphGoalCluster:
        case SCPropertyType_AnimGraphGoalMoveset:
        case SCPropertyType_AnimGraphGoalState:
        case SCPropertyType_AnimGraphGoalOverlay:
        case SCPropertyType_AnimGraphGoalMainhand:
        case SCPropertyType_AnimGraphGoalOffhand:
        case SCPropertyType_AnimGraphGoalNpc:
        case SCPropertyType_AnimGraphGoalClusterNpc:
        case SCPropertyType_AnimGraphGoalMovesetNpc:
        case SCPropertyType_AnimGraphGoalStateNpc:
        case SCPropertyType_AnimGraphGoalBBeam_or_TightRope:
            Ref nameRef;
            unsigned int value;
            break;
        
        case SCPropertyType_AnimGraphTrigger:
        case SCPropertyType_Event:
            /*EventEnum*/ unsigned int value <format=hex>;
            break;
        
        case SCPropertyType_Bark:
            Ref barkRef;
            if (CanSeekTo(barkRef))
            {
                SeekToRef(barkRef);
                StateControlBark bark;
                ReturnFromRef();
            }
            break;
        
        case SCPropertyType_CameraMoveStick:
            CameraMoveStick value;
            break;
        
        case SCPropertyType_Float:
        case SCPropertyType_FloatDistanceCm:
            float value;
            break;
            
        case SCPropertyType_InventoryState:
            /*InventoryStateEnum*/ unsigned int value <format=hex>;
            break;
        
        case SCPropertyType_PlayNotification:
            /*EnumPlayNotification*/ unsigned int value <format=hex>;
            break;
        
        case SCPropertyType_WeaponCameraType:
            /*WeaponCameraTypeEnum*/ unsigned int value <format=hex>;
            break;
        
        case SCPropertyType_StatusMenuState:
            /*EnumStatusMenuState*/ unsigned int value <format=hex>;
            break;
            
        case SCPropertyType_String:
            Ref valueRef;
            if (CanSeekTo(valueRef))
            {
                SeekToRef(valueRef);
                string value;
                ReturnFromRef();
            }
            break;
    }
    FSeek(endPos);
}

typedef struct
{
    SCStateProperty property;
    SCPropertyType type;
    ReadSCPropertyValue(type);
    Ref debugNameRef;
    if (CanSeekTo(debugNameRef))
    {
        SeekToRef(debugNameRef);
        string debugName;
        ReturnFromRef();
    }
} SCPropertyAssignment <optimize=false, read=ReadSCPropertyAssignment(this)>;

string ReadSCPropertyAssignment(SCPropertyAssignment& data)
{
    local string property = SubStr(EnumToString(data.property), 16);
    local string value;
    switch (data.type)
    {
        case SCPropertyType_Float:
        case SCPropertyType_FloatDistanceCm:
            value = Str("%f", data.value);
            break;
        
        case SCPropertyType_CameraMoveStick:
            value = Str("[%d, %d]", data.value.min, data.value.max);
            break;
        
        case SCPropertyType_String:
            value = data.value;
            break;
        
        default:
            value = exists(data.value) ? Str("%d", data.value) : "...";
            break;
    }
    return Str("%s = %s", property, value);
}

typedef struct
{
    short uniqueID;
    AnimReference animReference;
    short parentStateIdx;
