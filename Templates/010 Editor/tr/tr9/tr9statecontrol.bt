    short desiredState;
    short numModifiers;
    short numConditions;
    short modifierMask;
    Ref modifierListRef;
    if (CanSeekTo(modifierListRef))
    {
        SeekToRef(modifierListRef);
        short modifierList[numModifiers];
        ReturnFromRef();
    }
    Ref conditionListRef;
    if (CanSeekTo(conditionListRef))
    {
        SeekToRef(conditionListRef);
        SCCondition conditionList[numConditions];
        ReturnFromRef();
    }
    Ref debugNameRef;
    if (CanSeekTo(debugNameRef))
    {
        SeekToRef(debugNameRef);
        string debugName;
        ReturnFromRef();
    }
    byte debugShowPassFail;
    FSkip(3);
} SCTransition <optimize=false>;

typedef struct
