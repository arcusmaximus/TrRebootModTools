    ushort numProperties;
    ushort numActivities;
    ushort numTransitions;
    ushort numEventHandlers;
    ushort numEventSenders;
    Ref propertyListRef;
    if (CanSeekTo(propertyListRef))
    {
        SeekToRef(propertyListRef);
        SCPropertyAssignment propertyList[numProperties];
        ReturnFromRef();
    }
    Ref activityListRef;
    if (CanSeekTo(activityListRef))
    {
        SeekToRef(activityListRef);
        SCStateActivity activityList[numActivities];
        ReturnFromRef();
    }
    Ref transitionListRef;
    if (CanSeekTo(transitionListRef))
    {
        SeekToRef(transitionListRef);
        short transitionList[numTransitions];
        ReturnFromRef();
    }
    Ref eventHandlerListRef;
    if (CanSeekTo(eventHandlerListRef))
    {
        SeekToRef(eventHandlerListRef);
        short eventHandlerList[numEventHandlers];
        ReturnFromRef();
    }
    Ref eventSenderListRef;
    if (CanSeekTo(eventSenderListRef))
    {
        SeekToRef(eventSenderListRef);
        unsigned int eventSenderList[numEventSenders];
        ReturnFromRef();
    }
    Ref debugNameRef;
    if (CanSeekTo(debugNameRef))
    {
        SeekToRef(debugNameRef);
        string debugName;
        ReturnFromRef();
    }
} SCState <optimize=false>;

typedef struct
{
    SCCondContext context;
    local int endPos = FTell() + 0x10;
    switch (context)
    {
        case SCCondContext_Action:
            SCCondProperty property;
            INPUTACTION comparison;
            int not;
            break;
            
        case SCCondContext_CameraCategory:
            SCCondProperty property;
            unsigned int category;
            unsigned int categoryHash;
            int not;
            break;
        
        case SCCondContext_NamedValue_Boolean:
            short symbolId;
            FSkip(2);
            SCCondComparison comparison;
            int not;
            break;
        
        case SCCondContext_NamedValue_Scalar_EQ:
        case SCCondContext_NamedValue_Scalar_GT:
        case SCCondContext_NamedValue_Scalar_GTE:
            short symbolId;
            FSkip(2);
            float comparison;
            int not;
            break;
        
        case SCCondContext_NamedValue_Symbol_Comp:
            short symbolId1;
            short symbolId2;
            int not;
            break;
        
        case SCCondContext_MeleeMove:
        case SCCondContext_SeizeAttack:
            SCCondProperty property;
            Ref comparisonRef;
            int not;
            break;
            
        default:
            SCCondProperty property;
            SCCondComparison comparison;
            int not;
            break;
    }
    FSeek(endPos);
} SCCondition <optimize=false, read=ReadSCCondition(this)>;

string ReadSCCondition(SCCondition& condition)
{
    local string property;
    local string comparison;
    switch (condition.context)
    {
        case SCCondContext_Action:
            comparison = SubStr(EnumToString(condition.comparison), 12);
            break;
            
        case SCCondContext_NamedValue_Boolean:
            property = GetSymbolName(condition.symbolId);
            break;
        
        case SCCondContext_NamedValue_Scalar_EQ:
            return Str("%s %s %f", GetSymbolName(condition.symbolId), !condition.not ? "==" : "!=", condition.comparison);
        
        case SCCondContext_NamedValue_Scalar_GT:
            return Str("%s %s %f", GetSymbolName(condition.symbolId), !condition.not ? ">" : "<=", condition.comparison);
            
        case SCCondContext_NamedValue_Scalar_GTE:
            return Str("%s %s %f", GetSymbolName(condition.symbolId), !condition.not ? ">=" : "<", condition.comparison);
        
        case SCCondContext_NamedValue_Symbol_Comp:
            return Str("%s %s %s", GetSymbolName(condition.symbolId1), !condition.not ? "==" : "!=", GetSymbolName(condition.symbolId2));
    }
    
    if (Strlen(property) == 0)
        property = SubStr(EnumToString(condition.property), 15);
    
    if (Strlen(comparison) == 0)
    {
        if (exists(condition.comparison))
        {
            comparison = EnumToString(condition.comparison);
            comparison = Strlen(comparison) > 17 ? SubStr(comparison, 17) : Str("%d", condition.comparison);
        }
        else
        {
            comparison = "...";
        }
    }
    
    local string result = Str("%s %s", property, comparison);
    if (condition.not)
        result = Str("!(%s)", result);
    
    return result;
}

typedef struct
